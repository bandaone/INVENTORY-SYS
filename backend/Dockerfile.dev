FROM node:20-alpine

# Install dependencies for native modules
RUN apk add --no-cache python3 make g++ postgresql-client
RUN npm install -g @medusajs/cli@latest

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies with yarn to prevent network timeouts
RUN yarn install --network-timeout 1000000 --ignore-engines

# Copy source code
COPY . .

# Expose ports
EXPOSE 9000 7001

# Start development server
CMD ["npm", "run", "dev"]
