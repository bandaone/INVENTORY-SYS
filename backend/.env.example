# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/retail_os_dev
DATABASE_SSL=false
DATABASE_LOGGING=true

# Redis
REDIS_URL=redis://localhost:6379

# JWT & Cookies
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production

# CORS
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:3000,http://localhost:7001
AUTH_CORS=http://localhost:3000

# Backend URL
BACKEND_URL=http://localhost:9000

# Node Environment
NODE_ENV=development

# MTN MoMo
MTN_MOMO_API_KEY=your-api-key
MTN_MOMO_SUBSCRIPTION_KEY=your-subscription-key
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CALLBACK_URL=http://localhost:9000/webhooks/mtn

# Airtel Money
AIRTEL_API_KEY=your-api-key
AIRTEL_CLIENT_SECRET=your-client-secret
AIRTEL_ENVIRONMENT=sandbox
AIRTEL_CALLBACK_URL=http://localhost:9000/webhooks/airtel

# ZRA
ZRA_GATEWAY_URL=https://sandbox.zra.org.zm/api/v1
ZRA_TIMEOUT_MS=30000
